#version 450
#extension GL_EXT_mesh_shader : require
#extension GL_EXT_nonuniform_qualifier : require

layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = 6, max_primitives = 2) out;

layout(location = 1) out vec2 uv[];

layout(set=0, binding=0) buffer StorageBuffers {
    float data[];
} storageBuffers[];

layout(push_constant) uniform PushConstants {
    mat4 viewProjection;
    float zScale;
    uint vertexBufferRID;
    uint textureRID;
};

void main() {
    SetMeshOutputsEXT(6, 2);

    uint baseOffset = gl_GlobalInvocationID.x * 6 * 5;

    for (uint i = 0; i < 6; i++) {
        uint offset = baseOffset + i * 5;
        vec3 pos = vec3(
            storageBuffers[nonuniformEXT(vertexBufferRID)].data[offset],
            storageBuffers[nonuniformEXT(vertexBufferRID)].data[offset + 1],
            storageBuffers[nonuniformEXT(vertexBufferRID)].data[offset + 2]);
        gl_MeshVerticesEXT[i].gl_Position = viewProjection * vec4(pos, 1.0);
        uv[i] = vec2(
            storageBuffers[nonuniformEXT(vertexBufferRID)].data[offset + 3],
            storageBuffers[nonuniformEXT(vertexBufferRID)].data[offset + 4]);
    }

    gl_PrimitiveTriangleIndicesEXT[0] = uvec3(0, 1, 2);
    gl_PrimitiveTriangleIndicesEXT[1] = uvec3(3, 4, 5);
}
